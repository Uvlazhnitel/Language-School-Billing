# For public access, prefer an HTTPS reverse proxy or Tailscale Funnel URL, for example:
# APP_BASE_URL=https://homeserver.tailnet.ts.net
# Fallback for direct port exposure:
# APP_BASE_URL=http://203.0.113.10:8082
APP_BASE_URL=https://YOUR_PUBLIC_APP_HOST
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-please-set-a-long-random-value

APP_DATA_DIR=/var/lib/langschool/data
INVOICES_DIR=/var/lib/langschool/invoices
BACKUPS_DIR=/var/lib/langschool/backups
LS_FONTS_DIR=/app/Fonts
HOST=0.0.0.0
PORT=8080
